{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate && next build",
  "crons": [
    {
      "path": "/api/cron/recovery",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/billing",
      "schedule": "0 6 * * *"
    }
  ]
}
